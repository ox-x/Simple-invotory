<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Search Bar -->
    <EditText
        android:id="@+id/etWhSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rectangle_bg"
        android:hint="@string/wh_search_hint"
        android:inputType="text"
        android:padding="10dp"
        android:singleLine="true"
        android:textSize="13sp" />

    <!-- Overview Stats Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/rectangle_bg"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/warehouse_overview"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Row 1: Items | Boxes | Contents | Standalone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvWhStatItems"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#333333"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvWhStatBoxes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#333333"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvWhStatContents"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#333333"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvWhStatStandalone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="2dp"
            android:background="#CCCCCC" />

        <!-- Row 2: In Stock | Borrowed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvWhStatInStock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#4CAF50"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvWhStatBorrowed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FF5722"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Export Button -->
    <Button
        android:id="@+id/btnWhExport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/button_bg"
        android:text="@string/wh_export"
        android:textColor="@color/white"
        android:textSize="13sp" />

    <!-- Filter Buttons + View Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnWhFilterAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/button_bg"
            android:text="@string/wh_filter_all"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnWhFilterInStock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_bg_gray"
            android:text="@string/wh_filter_in_stock"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnWhFilterBorrowed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_bg_gray"
            android:text="@string/wh_filter_borrowed"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnWhViewToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/button_bg_gray"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="@string/wh_view_grid"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Content Area: List View (default) + Grid View -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1">

        <!-- List View (ScrollView + LinearLayout) -->
        <ScrollView
            android:id="@+id/svWhListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWhEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="32dp"
                    android:text="@string/wh_no_results"
                    android:textColor="#999999"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- List container (LinearLayout for ScrollView compat) -->
                <LinearLayout
                    android:id="@+id/llWhItemList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </ScrollView>

        <!-- Grid View (RecyclerView with GridLayoutManager) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWhGridView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Empty text for grid view -->
        <TextView
            android:id="@+id/tvWhGridEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="32dp"
            android:text="@string/wh_no_results"
            android:textColor="#999999"
            android:textSize="13sp"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
