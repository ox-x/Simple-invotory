<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page"
    android:padding="@dimen/sp_sm">

    <!-- ============ 顶部控制区卡片：学生ID + 功率 + 扫描按钮 ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sp_sm"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_checkout_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/sp_md">

            <!-- Student ID row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etStudentId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="@string/checkout_student_id"
                    android:inputType="text"
                    android:minHeight="40dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:singleLine="true"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnConfirmStudent"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="@dimen/sp_md"
                    android:background="@drawable/bg_btn_checkout_primary"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:text="OK"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStudentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/module_checkout"
                android:textSize="11sp" />

            <!-- Power Control -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sp_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCheckoutPower"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="@string/power_label"
                    android:textColor="@color/module_checkout"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/seekBarCheckoutPower"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="29"
                    android:progress="25" />
            </LinearLayout>

            <!-- Action Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sp_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnContinuousScan"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_checkout_primary"
                    android:text="@string/br_continuous_scan"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnStopScan"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="@dimen/sp_md"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_checkout_gray"
                    android:enabled="false"
                    android:text="@string/br_stop_scan"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ 筛选按钮卡片 ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sp_sm"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_checkout_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/sp_lg">

            <Button
                android:id="@+id/btnFilterAll"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_checkout_primary"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="@string/br_filter_all"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFilterInStock"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="@dimen/sp_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_checkout_gray"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="@string/br_filter_in_stock"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFilterBorrowed"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="@dimen/sp_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_checkout_gray"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="@string/br_filter_borrowed"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Button
                android:id="@+id/btnFilterAudited"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="@dimen/sp_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_checkout_gray"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="@string/br_filter_audited"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFilterNotAudited"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="@dimen/sp_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_checkout_gray"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="@string/br_filter_not_audited"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ Pending Actions Confirmation Bar ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sp_sm"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_checkout_light">

        <LinearLayout
            android:id="@+id/llConfirmBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/sp_lg"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvPendingCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/module_checkout"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnConfirmAction"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_btn_checkout_primary"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:text="@string/ok"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCancelAction"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/sp_md"
            android:background="@drawable/bg_btn_checkout_gray"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:text="@string/cancel"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ 批量操作卡片 ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sp_sm"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_checkout_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/sp_lg">

            <Button
                android:id="@+id/btnBulkAll"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_checkout_primary"
                android:text="@string/br_bulk_all"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCancelAll"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/sp_md"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_checkout_gray"
                android:text="@string/br_cancel_all"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/module_checkout"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ 扫描状态 ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sp_sm"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_checkout_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/sp_sm">

            <TextView
                android:id="@+id/tvScanStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/br_scan_status_ready"
                android:textColor="@color/module_checkout"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- 模拟器TID输入行 -->
            <LinearLayout
                android:id="@+id/llEmulatorTidInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etEmulatorTid"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="@string/br_emulator_tid_hint"
                    android:inputType="text"
                    android:singleLine="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnEmulatorTidConfirm"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_btn_checkout_primary"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:text="@string/ok"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ 物品列表卡片 ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_checkout_light">

        <ExpandableListView
            android:id="@+id/elvItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="@dimen/sp_md"
            android:childDivider="@android:color/transparent" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
