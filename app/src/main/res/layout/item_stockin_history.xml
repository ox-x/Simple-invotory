<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rectangle_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSiItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSiItemEpc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="middle"
            android:singleLine="true"
            android:textColor="#666666"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSiItemType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="4dp"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSiItemTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="10sp" />

    <Button
        android:id="@+id/btnSiItemDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:background="@drawable/button_bg_gray"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:text="@string/stockin_delete_record"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:visibility="gone" />
</LinearLayout>
